---
import { fetchProjects } from "../lib/github.ts";
import Icon from "./Icon.astro";
import ProjectMeta from "./ProjectMeta.astro";

// Fetched at build time — real stars/languages/fork flags baked into the HTML.
const projects = await fetchProjects();
const featured = projects.find((p) => p.featured);
const cards = projects.filter((p) => !p.featured);
---

<section id="projects" aria-label="Projects">
  <div class="section-inner">
    <p class="section-label"><Icon name="folder" class="label-icon" />Projects</p>
    <h1 class="section-title">What I've shipped</h1>
    <span class="rule" aria-hidden="true"></span>

    {featured && (
      <article class="featured" aria-label={`Featured project: ${featured.name}`}>
        <span class="featured-badge" aria-label="Featured project">Featured</span>
        <div>
          <h3 class="project-name">{featured.name}</h3>
          <p class="project-desc">{featured.desc}</p>
          <div class="meta"><ProjectMeta project={featured} /></div>
        </div>
        <a
          class="project-link"
          href={featured.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${featured.name} on GitHub`}
        >
          <Icon name="github" class="link-icon" />
          View on GitHub
        </a>
      </article>
    )}

    <div class="projects-grid" role="list">
      {cards.map((project) => (
        <a class="card" href={project.url} target="_blank" rel="noopener noreferrer" role="listitem">
          <span class="card-corner">
            {project.fork && (
              <>
                <Icon name="fork" class="card-fork" />
                <span class="sr-only">Forked repository</span>
              </>
            )}
            <Icon name="github" class="card-gh" />
          </span>
          <span class={project.org ? 'org-label' : 'org-label org-label--personal'}>
            {project.org ?? 'Personal'}
          </span>
          <span class="card-name">{project.name}</span>
          <p class="card-desc">{project.desc}</p>
          <div class="meta"><ProjectMeta project={project} /></div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #projects { background: var(--glass); }

  .featured {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 2.25rem 2.5rem;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    transition: border-color .2s;
  }

  .featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--frost) 0%, var(--lavender) 60%, transparent 100%);
  }

  .featured:hover {
    border-color: rgba(142, 207, 238, .28);
    box-shadow: 0 10px 44px rgba(142, 207, 238, .12);
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: .65rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(232, 184, 75, .08);
    border: 1px solid rgba(232, 184, 75, .25);
    padding: .2em .65em;
    border-radius: 3px;
  }

  .project-name {
    font-family: var(--ff-display);
    font-size: 1.55rem;
    color: #fff;
    margin-bottom: .4rem;
  }

  .project-desc {
    color: var(--sub);
    font-size: .93rem;
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 540px;
  }

  .meta {
    display: flex;
    gap: .6rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .project-link {
    display: flex;
    align-items: center;
    gap: .4em;
    color: var(--frost);
    text-decoration: none;
    font-size: .82rem;
    padding: .55em 1.1em;
    border: 1px solid var(--border);
    border-radius: var(--r);
    transition: background .2s, border-color .2s;
    white-space: nowrap;
    align-self: center;
  }

  .project-link:hover {
    background: var(--frost-dim);
    border-color: rgba(142, 207, 238, .3);
  }

  .projects-grid {
    display: grid;
    /* min(100%, 288px) keeps cards from overflowing on very narrow screens. */
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 288px), 1fr));
    gap: .75rem;
    margin-top: .75rem;
  }

  .card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.4rem 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    transition: transform .2s, border-color .2s;
  }

  .card:hover {
    border-color: rgba(142, 207, 238, .28);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(142, 207, 238, .12);
  }

  /* Top-right corner cluster: fork indicator (if any) + the GitHub mark. */
  .card-corner {
    position: absolute;
    top: 1.15rem;
    right: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
  }

  .card-name {
    font-size: .95rem;
    font-weight: 600;
    color: #fff;
  }

  .card-desc {
    font-size: .83rem;
    color: var(--sub);
    line-height: 1.6;
    flex: 1;
  }

  .org-label {
    font-size: .62rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--lavender);
  }

  .org-label--personal {
    color: var(--frost);
    opacity: .8;
  }

  @media (max-width: 768px) {
    .featured { grid-template-columns: 1fr; }

    .featured-badge {
      position: static;
      display: inline-block;
      margin-bottom: .75rem;
    }
  }
</style>
