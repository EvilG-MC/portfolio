---
import "../styles/global.css";
import ConsoleSignature from "../components/ConsoleSignature.astro";
import Footer from "../components/Footer.astro";
import FrostField from "../components/FrostField.astro";
import Nav from "../components/Nav.astro";
import { GITHUB_AVATAR } from "../lib/site.ts";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "JustEvil — Portfolio",
	description = "JustEvil — Engineering student and open-source Discord developer. Building TypeScript tooling under Ganyu Studios.",
	// Square avatar works well as a link-preview thumbnail. Absolute URL so it
	// resolves in embeds even before a custom domain is configured.
	image = GITHUB_AVATAR,
} = Astro.props;

// Absolute canonical URL — only emitted once `site` is set in astro.config so we
// never ship a localhost URL into an embed.
const canonical = Astro.site
	? new URL(Astro.url.pathname, Astro.site)
	: null;
---

<!doctype html>
<!--
     ❄  Hi there, source-viewer.  ❄
     Built with Astro, frost, and Ganyu as the muse. No trackers here.
     Open the console for a little something.  👀
-->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={GITHUB_AVATAR} type="image/png" />
    <title>{title}</title>

    <!-- Embeds: tints the accent bar of the Discord link preview -->
    <meta name="theme-color" content="#8ecfee" />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Open Graph (Discord, Facebook, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="JustEvil" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    {canonical && <meta property="og:url" content={canonical} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:creator" content="@NewJustEvil" />
  </head>
  <body>
    <FrostField />
    <Nav />
    <main class="page-content">
      <slot />
    </main>
    <Footer />
    <ConsoleSignature />
  </body>
</html>
