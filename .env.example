# Copy to `.env` and fill in. All are optional — the site falls back to defaults.

# Who the site is about. Used to render the GitHub profile/stats, avatar, and links.
# PUBLIC_ so it's also available to the client-side Discord card script.
PUBLIC_GITHUB_USER=the-github-username
PUBLIC_DISCORD_ID=the-discord-user-id

# Lifts the GitHub API limit from 60 → 5000 requests/hour at build time.
# Not PUBLIC_ — only read during the build, never shipped to the browser.
GITHUB_TOKEN=the-github-personal-access-token
